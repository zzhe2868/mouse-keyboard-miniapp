/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  background-color: #f5f5f5;
  color: #333;
  --theme-color: #ff6b35;
  --theme-dark: #1a1a2e;
  --card-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
}

::-webkit-scrollbar {
  width: 0;
  height: 0;
  background: transparent;
}
