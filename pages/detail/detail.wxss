/* pages/detail/detail.wxss — 商品详情页样式 */
.container {
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* ── 顶部大图 ── */
.hero {
  position: relative;
  width: 100%;
  height: 520rpx;
  background: linear-gradient(180deg, #1a1a2e 0%, #2d2d4a 60%, #f5f5f5 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.hero-img {
  width: 70%;
  height: 65%;
  filter: drop-shadow(0 20rpx 30rpx rgba(0,0,0,0.4));
}
.hero-overlay {
  position: absolute;
  bottom: 30rpx;
  left: 30rpx;
  right: 30rpx;
}
.hero-brand {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  letter-spacing: 4rpx;
  text-transform: uppercase;
}
.hero-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  margin-top: 6rpx;
}

/* ── 价格卡片 ── */
.price-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: -30rpx 24rpx 0;
  padding: 28rpx 30rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.1);
  position: relative;
  z-index: 10;
}
.price-main {
  color: #e0483b;
}
.price-symbol {
  font-size: 28rpx;
  font-weight: 700;
}
.price-value {
  font-size: 52rpx;
  font-weight: 800;
}
.price-tags {
  display: flex;
  gap: 10rpx;
}
.price-tag {
  font-size: 20rpx;
  color: #ff6b35;
  background: #fff5f0;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* ── 通用区块 ── */
.section {
  margin: 30rpx 24rpx 0;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 24rpx;
}
.title-dot {
  width: 10rpx;
  height: 28rpx;
  background: #ff6b35;
  border-radius: 6rpx;
  margin-right: 16rpx;
}
.dot-blue { background: #4a90d9; }
.dot-green { background: #4cd964; }
.dot-orange { background: #ff9500; }

/* ── 亮点 ── */
.highlights {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.highlight-item {
  flex: 0 0 47%;
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx;
  background: #fafafa;
  border-radius: 14rpx;
  font-size: 24rpx;
  color: #555;
}
.hl-icon { font-size: 28rpx; }

/* ── 参数表格 ── */
.specs-table {
  display: flex;
  flex-direction: column;
}
.spec-row {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.spec-row:last-child { border-bottom: none; }
.spec-label {
  width: 180rpx;
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}
.spec-value {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  text-align: right;
}

/* ── 描述 ── */
.desc-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

/* ── 底部操作栏 ── */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 20rpx rgba(0,0,0,0.06);
  z-index: 100;
}
.back-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 40rpx;
}
.share-btn {
  flex: 2;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #ff6b35, #f7931e);
  border-radius: 40rpx;
  border: none;
  line-height: 1;
}

/* ── 轮播推荐 ── */
.related-scroll {
  white-space: nowrap;
  display: flex;
  gap: 20rpx;
}
.related-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 160rpx;
  white-space: normal;
}
.related-img {
  width: 140rpx;
  height: 140rpx;
  background: #fafafa;
  border-radius: 16rpx;
}
.related-name {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #666;
  text-align: center;
}
.related-price {
  font-size: 26rpx;
  font-weight: 700;
  color: #e0483b;
  margin-top: 4rpx;
}
